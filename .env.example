# ─── Local development (SQLite — recommended) ───────────────────────────────
# Terminal 1: npm run server
# Terminal 2: npm run dev
# No VITE_API_URL needed; Vite proxies /api → http://localhost:5000

# ─── Vercel / production (PostgreSQL — required) ───────────────────────────
# Add these in Vercel → Project → Settings → Environment Variables, then redeploy.
# Use Vercel Postgres, Neon, or Supabase connection string:
POSTGRES_URL=postgresql://user:password@host:5432/database?sslmode=require

# Optional discrete fields instead of POSTGRES_URL:
# POSTGRES_HOST=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=
# POSTGRES_PORT=5432

# Only set if API is on a different domain (usually leave empty on Vercel):
# VITE_API_URL=
