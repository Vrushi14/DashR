# ─── Local development (SQLite — recommended) ───────────────────────────────
# Terminal 1: npm run server
# Terminal 2: npm run dev
# No VITE_API_URL needed; Vite proxies /api → http://localhost:5000

# ─── Vercel / production (Supabase Postgres — required for live login) ─────
# Copy from Supabase → Project Settings → Database → Connection string
# Add ALL of these in Vercel → Settings → Environment Variables → Redeploy

# Pooled (Transaction mode, port 6543) — use for POSTGRES_URL on Vercel
POSTGRES_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

# Direct (port 5432, db.xxx.supabase.co) — use for POSTGRES_URL_NON_POOLING
POSTGRES_URL_NON_POOLING=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Optional (DashRx does not use Supabase Auth SDK yet):
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Only if API is on another domain (leave empty on Vercel):
# VITE_API_URL=
